# ============================================================
# OKINTE PLATFORM — Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================


# ============================================================
# DATABASE (Supabase PostgreSQL)
# Get from: Supabase Dashboard → Project Settings → Database
# ============================================================
# Connection pooler URL (for serverless — uses port 6543)
DATABASE_URL="postgresql://postgres.fpvhvvyouhyzyeluopcm:si_8h%2FR6nKsr!DU@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?pgbouncer=true"
# Direct connection URL (for migrations — uses port 5432)
DIRECT_URL="postgresql://postgres.fpvhvvyouhyzyeluopcm:si_8h%2FR6nKsr!DU@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"


# ============================================================
# AUTH (JWT Secret — used to sign/verify auth tokens)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================================
JWT_SECRET="a1b2c3d4e5f6...your-64-char-hex-secret..."


# ============================================================
# SUPABASE (File Storage for documents/avatars)
# Get from: Supabase Dashboard → Project Settings → API
# ============================================================
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
# Service Role Key (has full access — never expose to client)
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inh4eHh4eHh4eHh4eCIsInJvbGUiOiJzZXJ2aWNlX3JvbGUifQ.XXXXXXXXXXXX"


# ============================================================
# STRIPE (Payment Processing)
# Get from: https://dashboard.stripe.com/apikeys
# ============================================================
# Secret key (server-side only — starts with sk_)
STRIPE_SECRET_KEY="sk_test_51XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# Publishable key (safe for client — starts with pk_)
STRIPE_PUBLISHABLE_KEY="pk_test_51XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# Webhook signing secret (from Stripe Dashboard → Webhooks → Signing secret)
STRIPE_WEBHOOK_SECRET="whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"


# ============================================================
# EMAIL (Resend — Transactional Emails)
# Get from: https://resend.com/api-keys
# ============================================================
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# Admin email to receive notifications (new applications, etc.)
ADMIN_EMAIL="admin@okinte.com"


# ============================================================
# UPSTASH REDIS (Distributed Rate Limiting)
# Required for rate limiting across serverless instances
# Get from: https://console.upstash.com/ → Create Database → REST API
# ============================================================
UPSTASH_REDIS_REST_URL="https://xxxxxxxx-xxxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXxxXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"


# ============================================================
# CRON (Scheduled Tasks — cleanup expired tokens, etc.)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This secret authenticates cron job requests to /api/cron/*
# ============================================================
CRON_SECRET="your-random-32-char-hex-secret-here"


# ============================================================
# APP (Public URL)
# ============================================================
# Production: https://www.okinte.com
# Local dev:  http://localhost:3000
NEXT_PUBLIC_APP_URL="https://www.okinte.com"


# ============================================================
# SENTRY (Error Monitoring & Performance Tracing)
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
# ============================================================
# DSN for error reporting (client + server)
NEXT_PUBLIC_SENTRY_DSN="https://xxxxxxxxxxxxxxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/1234567"
SENTRY_DSN="https://xxxxxxxxxxxxxxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/1234567"
# Auth token for source map uploads (build-time only — set in CI/CD, not .env)
# Get from: https://sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN="sntrys_eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
