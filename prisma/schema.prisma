// Prisma Schema for Okinte Platform
// This defines ALL database tables, relationships, and constraints.
// Run `npx prisma migrate dev` to apply changes to the database.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// USER: Anyone who registers on the platform
// Role: "user" (default) or "admin" (platform managers)
// ============================================================
model User {
  id            String   @id @default(uuid())
  firstName     String
  lastName      String
  email         String   @unique
  phone         String   @unique
  country       String
  city          String
  passwordHash  String
  role          Role     @default(USER)
  emailVerified Boolean  @default(false)
  verificationToken       String?   @unique
  verificationTokenExpires DateTime?
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  avatarUrl        String?   // User profile picture URL
  tokenVersion     Int       @default(0)  // Incremented on password change to invalidate sessions
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations: a user can have many applications, documents, payments, messages
  applications Application[]
  documents    Document[]
  payments     Payment[]
  messages     Message[]
  chatMessages ChatMessage[]
  testimonials Testimonial[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

// ============================================================
// SERVICE: The 5 core services Okinte offers
// Stored in DB so admin can edit names, descriptions, prices
// ============================================================
model Service {
  id          String  @id @default(uuid())
  key         String  @unique // "study", "internship", "scholarship", "sabbatical", "employment"
  price       Decimal @default(150.00)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  applications Application[]

  @@map("services")
}

// ============================================================
// APPLICATION: A user's request for a specific service
// Goes through: draft → submitted → under_review → approved/rejected
// ============================================================
model Application {
  id            String            @id @default(uuid())
  userId        String
  serviceId     String
  referenceCode String            @unique // e.g., "BOL-2026-A3F8K2"
  status        ApplicationStatus @default(DRAFT)
  notes         String?           // Admin review notes
  userResponse  String?           // User's response when resubmitting a RETURNED application
  submittedAt   DateTime?
  reviewedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  service   Service    @relation(fields: [serviceId], references: [id])
  documents Document[]
  payment   Payment?

  @@index([userId])
  @@index([serviceId])
  @@index([status])
  @@index([createdAt])
  @@map("applications")
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  RETURNED
}

// ============================================================
// DOCUMENT: Files uploaded by users (passport, CV, diploma, receipt)
// Files stored in Supabase Storage; this table stores metadata
// ============================================================
model Document {
  id            String       @id @default(uuid())
  userId        String
  applicationId String
  type          DocumentType
  fileName      String       // Original filename
  storagePath   String       // Path in Supabase Storage bucket
  mimeType      String       // "application/pdf", "image/jpeg", etc.
  fileSize      Int          // Size in bytes
  uploadedAt    DateTime     @default(now())

  // Relations
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // Unique constraint: one document per type per application (enables atomic upsert)
  @@unique([applicationId, type], name: "applicationId_type_unique")
  @@index([userId])
  @@index([applicationId])
  @@map("documents")
}

enum DocumentType {
  PASSPORT
  CV
  DIPLOMA
  PAYMENT_RECEIPT
}

// ============================================================
// PAYMENT: Tracks Stripe payment for each application
// Status updates via Stripe webhooks
// ============================================================
model Payment {
  id                    String        @id @default(uuid())
  userId                String
  applicationId         String        @unique // One payment per application
  stripeSessionId       String?       @unique
  stripePaymentIntentId String?       @unique
  amount                Decimal
  currency              String        @default("usd")
  status                PaymentStatus @default(PENDING)
  discount              Decimal?      // Discount amount applied via promo code
  promoCodeId           String?       // Reference to promo code used
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  // Relations
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([status])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ============================================================
// PARTNER: Institutions and companies that partner with Okinte
// Managed by admin; displayed on the platform
// ============================================================
model Partner {
  id        String   @id @default(uuid())
  name      String
  logoUrl   String?
  website   String?
  country   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("partners")
}

// ============================================================
// MESSAGE: Contact form submissions from visitors
// userId is optional (anonymous visitors can send messages too)
// ============================================================
model Message {
  id        String   @id @default(uuid())
  userId    String?  // Nullable: anonymous visitors can send messages
  name      String
  email     String
  phone     String?
  message   String
  isRead    Boolean  @default(false)
  repliedBy String?
  repliedAt DateTime?
  createdAt DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([isRead])
  @@index([createdAt])
  @@map("messages")
}

// ============================================================
// WEBHOOK_EVENT: Tracks processed Stripe webhook events for atomic idempotency
// Prevents duplicate processing of the same event (e.g., due to retries)
// Stripe sends each event exactly once with a unique event.id
// ============================================================
model WebhookEvent {
  id          String   @id // Use Stripe's event.id as the primary key
  type        String   // Event type (e.g., "checkout.session.completed")
  processedAt DateTime @default(now())

  @@map("webhook_events")
}

// ============================================================
// PROMO CODE: Discount codes created by admin
// Supports percentage or fixed amount discounts
// ============================================================
model PromoCode {
  id          String    @id @default(uuid())
  code        String    @unique
  type        PromoType
  value       Decimal   // e.g., 20 for 20% or 20 for $20 off
  maxUses     Int?      // null = unlimited
  currentUses Int       @default(0)
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("promo_codes")
}

enum PromoType {
  PERCENTAGE
  FIXED
}

// ============================================================
// CHAT MESSAGE: Persistent messaging between admin and users
// Each message belongs to a user conversation thread
// ============================================================
model ChatMessage {
  id        String   @id @default(uuid())
  userId    String   // The user this conversation belongs to
  senderId  String   // Who sent it (userId or adminId)
  content   String
  isAdmin   Boolean  @default(false)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("chat_messages")
}

// ============================================================
// TESTIMONIAL: User reviews and feedback about services
// Submitted by users after receiving services
// ============================================================
model Testimonial {
  id        String   @id @default(uuid())
  userId    String
  rating    Int      // 1-5 stars
  content   String   // Review text (10-500 chars)
  isApproved Boolean @default(false) // Admin can moderate before display
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([rating])
  @@index([isApproved])
  @@index([createdAt])
  @@map("testimonials")
}
