# ============================================================
# DATABASE (Supabase PostgreSQL)
# ============================================================
DATABASE_URL=""
DIRECT_URL=""

# ============================================================
# AUTH (JWT Secret - used to sign/verify tokens)
# ============================================================
JWT_SECRET=""

# ============================================================
# SUPABASE (for File Storage)
# ============================================================
SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# ============================================================
# STRIPE (Payment)
# ============================================================
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ============================================================
# EMAIL (Resend)
# ============================================================
RESEND_API_KEY=""
ADMIN_EMAIL=""

# ============================================================
# UPSTASH REDIS (Distributed Rate Limiting)
# Required for rate limiting across multiple server instances
# Get from https://console.upstash.com/
# ============================================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ============================================================
# CRON (Scheduled Tasks)
# Secret token to authenticate cron job requests
# Used for cleanup and maintenance tasks
# ============================================================
CRON_SECRET=""

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL="https://www.okinte.com"

# ============================================================
# SENTRY (Error Monitoring & Tracing)
# NOTE: SENTRY_AUTH_TOKEN is used only at build time for source map uploads
# It should NOT be included in .env at runtime; configure it in CI/CD instead
# ============================================================
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
